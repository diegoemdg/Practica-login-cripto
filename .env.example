PORT=3000
APP_URL=http://localhost:3000

# Supabase > Project Settings > API
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Secreto local. No lo guardes en la base de datos.
PASSWORD_PEPPER=cambia-este-secreto-largo-y-aleatorio

# Recomendado para Render Free: Brevo API por HTTPS.
# Crea una API key en Brevo y verifica el remitente.
BREVO_API_KEY=TU_BREVO_API_KEY
MAIL_FROM="Practica Criptografia <tu-correo-verificado@example.com>"

# Respaldo local por SMTP. Render Free bloquea puertos SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@example.com
SMTP_PASS=password-del-smtp
